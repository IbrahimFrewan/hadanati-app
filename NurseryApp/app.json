{
  "expo": {
    "name": "حضانتي - Nursery",
    "slug": "HadanatiNursery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2f5e41"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hadanati.nursery"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2f5e41"
      },
      "package": "com.hadanati.nursery"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-font"]
  }
}
