# Copy to `.env` and fill from your Supabase project (Settings → API).
# Expo inlines EXPO_PUBLIC_* at build time. When these are unset the app runs
# entirely on its local store (no backend calls) — so it still works offline.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
